---
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} Huang Yuan. All rights reserved.
	<div class="footer-links">
		<span>Powered by <a href="https://astro.build" target="_blank">Astro</a></span>
		<span>·</span>
		<span>Deployed on <a href="https://pages.cloudflare.com" target="_blank">Cloudflare Pages</a></span>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
		font-size: 0.9em;
	}
	.footer-links {
		display: flex;
		justify-content: center;
		gap: 0.5em;
		margin-top: 0.5em;
	}
	.footer-links a { color: rgb(var(--gray)); }
	.footer-links a:hover { color: rgb(var(--gray-dark)); }
</style>
